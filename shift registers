module siso (
    input clk, reset,
    input serial_in,
    output serial_out
);

reg [3:0] q;

always @(posedge clk or posedge reset) begin
    if (reset)
        q <= 4'b0000;
    else
        q <= {serial_in, q[3:1]};  // shift right
end

assign serial_out = q[0];

endmodule







module sipo (
    input clk, reset,
    input serial_in,
    output reg [3:0] q
);

always @(posedge clk or posedge reset) begin
    if (reset)
        q <= 4'b0000;
    else
        q <= {serial_in, q[3:1]};  // shift right
end

endmodule





module piso (
    input clk, reset,
    input load,
    input [3:0] parallel_in,
    output serial_out
);

reg [3:0] q;

always @(posedge clk or posedge reset) begin
    if (reset)
        q <= 4'b0000;
    else if (load)
        q <= parallel_in;          // load parallel data
    else
        q <= {1'b0, q[3:1]};       // shift right
end

assign serial_out = q[0];

endmodule






module pipo (
    input clk, reset,
    input [3:0] parallel_in,
    output reg [3:0] q
);

always @(posedge clk or posedge reset) begin
    if (reset)
        q <= 4'b0000;
    else
        q <= parallel_in;   // direct load
end

endmodule
